# -----------------------------------------------------------------------------
# Native app handoff: secret to sign the token the Mac app receives via the
# justenv:// deeplink (/app-auth → /api/app/entitlement). Generate with:
#   openssl rand -hex 32
# Dedicated secret (NOT NEXTAUTH_SECRET) so app-token lifetime is decoupled.
# -----------------------------------------------------------------------------
APP_TOKEN_SECRET=